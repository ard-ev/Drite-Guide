{
  "expo": {
    "name": "Dritë Guide",
    "slug": "drite-guide",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.jpeg",
    "scheme": "driteguide",
    "userInterfaceStyle": "automatic",
    "backgroundColor": "#F5F5F5",
    "primaryColor": "#d51e1e",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "backgroundColor": "#F5F5F5",
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png",
        "backgroundColor": "#d51e1e"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/logo.jpeg"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Dritë Guide to access your photos so you can set a profile picture.",
          "cameraPermission": "Allow Dritë Guide to use your camera so you can take a profile picture."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "image": "./assets/splash-icon.png",
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-video"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "apiBaseUrl": "https://drite-guide-api-production.up.railway.app/api/v1"
    }
  }
}