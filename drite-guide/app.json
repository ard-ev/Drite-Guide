{
  "expo": {
    "name": "Dritë Guide",
    "slug": "drite-guide",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "scheme": "driteguide",
    "userInterfaceStyle": "automatic",
    "backgroundColor": "#F5F5F5",
    "primaryColor": "#d51e1e",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "cover",
      "backgroundColor": "#d51e1e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.driteguide.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Dritë Guide uses the camera so you can take a profile picture.",
        "NSPhotoLibraryUsageDescription": "Dritë Guide uses your photo library so you can choose a profile picture.",
        "NSLocationWhenInUseUsageDescription": "Dritë Guide uses your location to show nearby places on the map."
      }
    },
    "android": {
      "package": "com.driteguide.app",
      "backgroundColor": "#F5F5F5",
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png",
        "backgroundColor": "#d51e1e"
      },
      "predictiveBackGestureEnabled": false,
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.RECORD_AUDIO"
      ],
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "output": "single",
      "favicon": "./assets/logo.png"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Dritë Guide uses your photo library so you can choose a profile picture.",
          "cameraPermission": "Dritë Guide uses the camera so you can take a profile picture."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Dritë Guide uses your location to show nearby places on the map."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "resizeMode": "cover",
          "backgroundColor": "#d51e1e"
        }
      ],
      "expo-video",
      "expo-secure-store"
    ],
    "experiments": {
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "63c4a0a0-9434-4839-98fe-9e82bccad51a"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/63c4a0a0-9434-4839-98fe-9e82bccad51a"
    }
  }
}
