APP_NAME=Drite Guide API
APP_VERSION=0.1.0
API_V1_PREFIX=/api/v1
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/drite_guide
SYNC_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/drite_guide
# Railway example:
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@switchyard.proxy.rlwy.net:48686/railway
# Or set PGHOST, PGPORT, PGUSER, PGPASSWORD and PGDATABASE separately.
SECRET_KEY=7a080dcf8ee3cb4b5cc485eb488f84f64c1c301fb91c4913ebe7d636ac7ac3ca
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14
EMAIL_VERIFICATION_EXPIRE_HOURS=48
ALGORITHM=HS256
BACKEND_CORS_ORIGINS=["*"]
DEFAULT_LANGUAGE=en
DEFAULT_PROFILE_PICTURE=uploads/profile_pictures/default-profile.png
MAX_UPLOAD_SIZE_BYTES=5242880
FRONTEND_BASE_URL=https://drite-guide-production.up.railway.app
BACKEND_PUBLIC_BASE_URL=https://drite-guide-api-production.up.railway.app

# Optional. If these are not set, verification links are logged instead of sent.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Drite Guide
SMTP_USE_TLS=true
