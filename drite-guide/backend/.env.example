APP_NAME=Drite Guide API
APP_VERSION=0.1.0
API_V1_PREFIX=/api/v1
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/drite_guide
SYNC_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/drite_guide
SECRET_KEY=change-me-to-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14
EMAIL_VERIFICATION_EXPIRE_HOURS=48
ALGORITHM=HS256
BACKEND_CORS_ORIGINS=["*"]
DEFAULT_LANGUAGE=en
DEFAULT_PROFILE_PICTURE=uploads/profile_pictures/default-profile.svg
MAX_UPLOAD_SIZE_BYTES=5242880
FRONTEND_BASE_URL=http://localhost:8081
